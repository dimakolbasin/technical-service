<!doctype html>
<html lang="<%= lang.code %>">

<head>
	<!-- Google tag (gtag.js) -->
	<script async src="https://www.googletagmanager.com/gtag/js?id=G-YNHFGRED9Z"></script>
	<script>
		window.dataLayer = window.dataLayer || [];
		function gtag(){dataLayer.push(arguments);}
		gtag('js', new Date());

		gtag('config', 'G-YNHFGRED9Z');
	</script>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="format-detection" content="telephone=no">
	<meta name="robots" content="<%= typeof robots !== 'undefined' && robots ? robots : 'index, follow' %>">
	<meta name="theme-color" content="#f6f9fb">
	<title>
		<%= title %>
	</title>
	<meta name="description" content="<%= description %>">
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
	<noscript>
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
	</noscript>
	<link rel="preload" href="/assets/styles.css" as="style">
	<link rel="stylesheet" href="/assets/styles.css">
	<% if (pageKey === "home") { %>
		<link rel="preload" href="/assets/images/hero-appliances-mobile.webp" as="image" type="image/webp" media="(max-width: 719px)" fetchpriority="high">
		<link rel="preload" href="/assets/images/hero-appliances-desktop.webp" as="image" type="image/webp" media="(min-width: 720px)" fetchpriority="high">
	<% } %>
    <link rel="manifest" href="/manifest.json" crossorigin="use-credentials">
	<link rel="icon" href="/favicon.ico" type="image/x-icon" fetchpriority="low">
	<link rel="icon" href="/assets/icons/icon-tools.png" type="image/png" fetchpriority="low">
	<link rel="apple-touch-icon" href="/assets/icons/icon-tools.png" fetchpriority="low">
	<link rel="canonical" href="<%= pageKey ? site.baseUrl + lang.paths[pageKey] : site.baseUrl + '/' %>">
	<% if (pageKey) { %>
		<% i18n.languages.forEach((locale) => { %>
			<link rel="alternate" hreflang="<%= locale.code %>" href="<%= site.baseUrl + locale.paths[pageKey] %>">
		<% }); %>
		<link rel="alternate" hreflang="x-default" href="<%= site.baseUrl + i18n.languages[0].paths[pageKey] %>">
	<% } %>
	<% if (pageKey) { %>
		<meta property="og:type" content="website">
		<meta property="og:url" content="<%= site.baseUrl + lang.paths[pageKey] %>">
		<meta property="og:title" content="<%= title %>">
		<meta property="og:description" content="<%= description %>">
		<meta property="og:site_name" content="<%= site.name %>">
		<meta property="og:locale" content="<%= lang.code %>">
		<meta property="og:image" content="<%= site.baseUrl %>/assets/icons/meta-pic.webp">
	<% } %>
	<% if (pageKey) { %>
		<%
		const pageUrl = site.baseUrl + lang.paths[pageKey];
		const waNumber = site.phone.replace(/[^0-9]/g, "");
		const address = site.address || {};
		const addressLocality = address.locality || "Batumi";
		const addressCountry = address.country || "GE";
		const areaServed = Array.isArray(lang.areasList) && lang.areasList.length ? lang.areasList : "Batumi";
		const hasMap = [site.googleMaps, site.yandexMaps].filter(Boolean);
		const priceRange = site.priceRange || "GEL 20+";
		const sameAs = [site.telegram, `https://wa.me/${waNumber}`, site.facebook].filter(Boolean);
		const pageFaq = pageKey === "home"
			? (lang.home && lang.home.faq ? lang.home.faq : null)
			: (lang.pages && lang.pages[pageKey] ? lang.pages[pageKey].faq : null);
		const faqSchema = pageFaq && Array.isArray(pageFaq.items) && pageFaq.items.length
			? {
				"@context": "https://schema.org",
				"@type": "FAQPage",
				"mainEntity": pageFaq.items.map((item) => ({
					"@type": "Question",
					"name": item.question,
					"acceptedAnswer": {
						"@type": "Answer",
						"text": item.answer
					}
				}))
			}
			: null;

		const localBusiness = {
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": site.name,
			"url": pageUrl,
			"telephone": site.phone,
			"description": description,
			"image": `${site.baseUrl}/assets/icons/meta-pic.webp`,
			"address": {
				"@type": "PostalAddress",
				"streetAddress": address.street,
				"postalCode": address.postalCode,
				"addressLocality": addressLocality,
				"addressRegion": address.region,
				"addressCountry": addressCountry
			},
			"areaServed": areaServed,
			"hasMap": hasMap.length ? hasMap : undefined,
			"priceRange": priceRange,
			"openingHoursSpecification": [
				{
					"@type": "OpeningHoursSpecification",
					"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
					"opens": "09:00",
					"closes": "20:00"
				}
			],
			"sameAs": sameAs
		};

		const servicePageKeys = ["washing-machines", "dishwashers", "hobs", "ovens", "ac-cleaning", "refrigerators", "dryers", "gas-boilers"];
		const isServicePage = servicePageKeys.includes(pageKey);
		const serviceSchema = isServicePage
			? {
				"@context": "https://schema.org",
				"@type": "Service",
				"name": title,
				"serviceType": title,
				"provider": {
					"@type": "LocalBusiness",
					"name": site.name,
					"telephone": site.phone,
					"url": site.baseUrl
				},
				"areaServed": areaServed,
				"url": pageUrl,
				"description": description
			}
			: null;

		const breadcrumbs = {
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": i18n.languages.find((l) => l.code === lang.code)?.nav?.[0]?.label || "Home",
					"item": site.baseUrl + lang.paths.home
				},
				...(pageKey && pageKey !== "home"
					? [
						{
							"@type": "ListItem",
							"position": 2,
							"name": title,
							"item": pageUrl
						}
					]
					: [])
			]
		};
		%>
		<script type="application/ld+json"><%- JSON.stringify(localBusiness) %></script>
		<script type="application/ld+json"><%- JSON.stringify(breadcrumbs) %></script>
		<% if (serviceSchema) { %>
			<script type="application/ld+json"><%- JSON.stringify(serviceSchema) %></script>
		<% } %>
		<% if (faqSchema) { %>
			<script type="application/ld+json"><%- JSON.stringify(faqSchema) %></script>
		<% } %>
	<% } %>
</head>

<%
const trackingServicePageKeys = ["washing-machines", "dishwashers", "hobs", "ovens", "ac-cleaning", "refrigerators", "dryers", "gas-boilers"];
const trackingArticlePageKeys = ["washing-machine-not-draining", "dishwasher-not-draining", "oven-not-heating", "hob-not-turning-on", "ac-not-cooling", "ac-cleaning-importance"];
const trackingPageType = !pageKey
	? "error"
	: trackingServicePageKeys.includes(pageKey)
		? "service"
		: trackingArticlePageKeys.includes(pageKey)
			? "article"
			: ["home", "services", "prices", "contacts", "privacy"].includes(pageKey)
				? "core"
				: "page";
%>
<body class="page <%= pageKey === 'home' ? 'page--home' : 'page--subpage' %>"
	data-page-key="<%= pageKey || '' %>"
	data-page-type="<%= trackingPageType %>"
	data-page-language="<%= lang.code %>"
	data-ga-tracking="<%= pageKey ? 'enabled' : 'disabled' %>">
	<header class="site-header">
		<div class="container site-header__row">
			<a class="site-header__brand" href="<%= lang.paths.home %>">
				<img src="/assets/icons/icon-tools.png" alt="" class="site-header__logo" width="32"
					height="32">
				<span>
					<%= site.name %>
				</span>
			</a>
			<nav class="site-header__nav" aria-label="<%= lang.navLabel %>">
				<ul class="site-header__nav-list">
					<% lang.nav.forEach((item) => {
						const navActive = item.key === pageKey ? " site-header__nav-link--active" : "";
						%>
					<li><a class="site-header__nav-link<%= navActive %>" href="<%= lang.paths[item.key] %>">
							<%= item.label %>
						</a></li>
					<% }); %>
				</ul>
			</nav>
			<div class="site-header__contact">
				<a class="site-header__phone" href="tel:<%= site.phone %>" data-ga-contact-method="call" data-ga-location="header_phone">
                    591 17 23 29
				</a>
				<span>
					<%= lang.hours %>
				</span>
			</div>
				<% if (typeof hideLanguageSelector === "undefined" || !hideLanguageSelector) { %>
				<div class="site-header__langs" aria-label="<%= lang.langLabel %>">
					<%
					const headerLangs = ["ru", "ka", "en"]
						.map((code) => i18n.languages.find((locale) => locale.code === code))
						.filter(Boolean);
					headerLangs.forEach((locale) => {
					const activeClass = locale.code === lang.code ? " site-header__lang--active" : "";
					const targetKey = pageKey || "home";
					const href = (locale.paths && locale.paths[targetKey]) || locale.paths.home || "/";
					%>
					<a class="site-header__lang<%= activeClass %>" href="<%= href %>" data-lang="<%= locale.code %>" data-ga-language-switch="header">
						<%= locale.labelShort %>
					</a>
						<% }); %>
				</div>
				<% } %>
			</div>
		</header>

	<div class="site-nav">
		<nav class="container site-nav__panel" aria-label="<%= lang.navLabel %>">
			<ul class="site-nav__list">
				<% lang.nav.forEach((item) => {
					const navActive = item.key === pageKey ? " site-nav__link--active" : "";
					%>
				<li><a class="site-nav__link<%= navActive %>" href="<%= lang.paths[item.key] %>">
						<%= item.label %>
					</a></li>
				<% }); %>
			</ul>
		</nav>
	</div>

	<main class="main">
		<%- content %>
	</main>

	<% if (typeof hideFooter === "undefined" || !hideFooter) { %>
	<footer class="site-footer">
		<%
		const footer = lang.footer || {};
		const footerContact = lang.home && lang.home.contact ? lang.home.contact : {};
		const footerForm = footerContact.form || {};
		const footerContactItems = Array.isArray(footerContact.list) ? footerContact.list : [];
		const footerItem = (type) => footerContactItems.find((item) => item.type === type) || {};
		const footerAddress = footerItem("address").value || "";
		const footerHours = footerItem("hours").value || "";
		const footerAreas = footerItem("area").value || footer.areas || "";
		const waNumber = site.phone.replace(/[^0-9]/g, "");
		const hideFooterHero = pageKey === "privacy";
		%>
		<div class="container">
			<% if (!hideFooterHero) { %>
			<div class="footer-hero">
				<div class="footer-hero__content">
					<p class="footer-eyebrow">
						<%= footer.eyebrow %>
					</p>
					<h2 class="footer-hero__title">
						<%= footer.ctaTitle || footerContact.title %>
					</h2>
					<p class="footer-hero__lead">
						<%= footer.ctaLead || footerContact.lead %>
					</p>
					<div class="footer-actions">
						<a class="button button--primary" href="tel:<%= site.phone %>" data-ga-contact-method="call" data-ga-location="footer_actions">
							<img class="button__icon" src="/assets/icons/social/call.png" alt="" width="24" height="24">
							<%= footer.callLabel || lang.cta %>
						</a>
						<a class="button button--ghost" href="https://wa.me/<%= waNumber %>" target="_blank" rel="noopener" data-ga-contact-method="whatsapp" data-ga-location="footer_actions">
							<img class="button__icon" src="/assets/icons/social/wh-1.png" alt="" width="24" height="24">
							<%= footer.messageLabel || lang.ctaMessage || "WhatsApp" %>
						</a>
					</div>
					<div class="footer-social" aria-label="<%= footer.contactsTitle %>">
						<a class="card__icon card__icon--social" href="<%= site.telegram %>" target="_blank" rel="noopener" aria-label="Telegram" data-ga-contact-method="telegram" data-ga-location="footer_social">
							<img src="/assets/icons/social/tg.png" alt="" width="24" height="24">
						</a>
						<a class="card__icon card__icon--social" href="https://wa.me/<%= waNumber %>" target="_blank" rel="noopener" aria-label="WhatsApp" data-ga-contact-method="whatsapp" data-ga-location="footer_social">
							<img src="/assets/icons/social/wh-1.png" alt="" width="24" height="24">
						</a>
						<a class="card__icon card__icon--social" href="<%= site.viber %>" target="_blank" rel="noopener" aria-label="Viber" data-ga-contact-method="viber" data-ga-location="footer_social">
							<img src="/assets/icons/social/viber.png" alt="" width="24" height="24">
						</a>
						<% if (site.facebook) { %>
							<a class="card__icon card__icon--social" href="<%= site.facebook %>" target="_blank" rel="noopener" aria-label="Facebook" data-ga-contact-method="facebook" data-ga-location="footer_social">
								<img src="/assets/icons/social/fb.png" alt="" width="24" height="24">
							</a>
						<% } %>
					</div>
					<div class="footer-contact-grid">
						<div class="footer-contact-item">
							<span><%= footer.phoneLabel %></span>
							<a href="tel:<%= site.phone %>" data-ga-contact-method="call" data-ga-location="footer_contact_grid"><%= site.phone %></a>
						</div>
						<% if (footerHours) { %>
							<div class="footer-contact-item">
								<span><%= footer.hoursTitle %></span>
								<p><%= footerHours %></p>
							</div>
						<% } %>
						<% if (footerAddress) { %>
							<div class="footer-contact-item">
								<span><%= footerItem("address").label || footer.contactsTitle %></span>
								<p><%= footerAddress %></p>
							</div>
						<% } %>
						<% if (footerAreas) { %>
							<div class="footer-contact-item footer-contact-item--wide">
								<span><%= footer.areasTitle %></span>
								<p><%= footerAreas %></p>
							</div>
						<% } %>
					</div>
					</div>
				<% if (lang.home && lang.home.contact) { %>
					<div class="footer-form-panel">
						<h2 class="footer-form-panel__title">
							<%= footer.formTitle || footerContact.title %>
						</h2>
						<p class="footer-form-panel__text">
							<%= footerContact.lead %>
						</p>
						<form class="form footer-form" id="lead-form-footer" name="lead-form-footer" action="https://api.web3forms.com/submit" method="POST" autocomplete="off">
							<input type="hidden" name="access_key" value="<%= site.web3formsAccessKey %>">
							<input type="hidden" name="subject" value="New repair request from site footer">
							<input type="hidden" name="from_name" value="Repair Service Request">
							<div class="form__row">
								<label class="form__label" for="name-footer">
									<%= footerForm.nameLabel %>
								</label>
								<input autocomplete="off" class="form__input" type="text" id="name-footer" name="name"
									placeholder="<%= footerForm.namePlaceholder %>">
							</div>
							<div class="form__row">
								<label class="form__label" for="phone-footer">
									<%= footerForm.phoneLabel %>
								</label>
								<div class="form__phone-group">
									<input autocomplete="off" class="form__input form__input--phone" type="number" min="0"
										id="phone-footer" name="phone" placeholder="<%= footerForm.phonePlaceholder %>"
										inputmode="tel" required
										oninvalid="this.setCustomValidity('<%= footerForm.phoneRequired %>')"
										oninput="this.setCustomValidity('')">
									<div class="form__contact-methods" role="group" aria-label="<%= footerForm.preferredContactLabel %>">
										<span class="form__contact-methods-note">
											<%= footerForm.preferredContactLabel %>
										</span>
										<input class="form__contact-method-input" type="checkbox" id="preferred-contact-footer-call"
											name="preferredContact[]" value="call" aria-label="<%= footer.callLabel || 'Call' %>">
										<label class="form__contact-method" for="preferred-contact-footer-call" title="<%= footer.callLabel || 'Call' %>">
											<span class="visually-hidden"><%= footer.callLabel || 'Call' %></span>
											<img class="button__icon" src="/assets/icons/social/call.png" alt="" width="24" height="24">
										</label>
										<input class="form__contact-method-input" type="checkbox" id="preferred-contact-footer-tg"
											name="preferredContact[]" value="telegram" aria-label="Telegram">
										<label class="form__contact-method" for="preferred-contact-footer-tg" title="Telegram">
											<span class="visually-hidden">Telegram</span>
											<img class="button__icon" src="/assets/icons/social/tg.png" alt="" width="24" height="24">
										</label>
										<input class="form__contact-method-input" type="checkbox" id="preferred-contact-footer-wh"
											name="preferredContact[]" value="whatsapp" aria-label="WhatsApp">
										<label class="form__contact-method" for="preferred-contact-footer-wh" title="WhatsApp">
											<span class="visually-hidden">WhatsApp</span>
											<img class="button__icon" src="/assets/icons/social/wh-1.png" alt="" width="24" height="24">
										</label>
										<input class="form__contact-method-input" type="checkbox" id="preferred-contact-footer-viber"
											name="preferredContact[]" value="viber" aria-label="Viber">
										<label class="form__contact-method" for="preferred-contact-footer-viber" title="Viber">
											<span class="visually-hidden">Viber</span>
											<img class="button__icon" src="/assets/icons/social/viber.png" alt="" width="24" height="24">
										</label>
									</div>
								</div>
							</div>
							<div class="form__row">
								<label class="form__label" for="message-footer">
									<%= footerForm.descriptionLabel %>
								</label>
								<textarea class="form__input" id="message-footer" name="message" rows="3"
									placeholder="<%= footerForm.descriptionPlaceholder %>" autocomplete="off"
									aria-autocomplete="none"></textarea>
							</div>
							<div class="form__actions">
								<button class="button button--primary" type="submit">
									<%= footerForm.submit %>
								</button>
							</div>
						</form>
					</div>
				<% } %>
			</div>
			<% } %>
			<div class="footer-bottom">
				<%
				const privacyPath = (lang.paths && lang.paths.privacy) || "/privacy/";
				const privacyLabel = lang.pages.privacy.linkLabel;
				const footerLangs = ["ru", "ka", "en"]
					.map((code) => i18n.languages.find((locale) => locale.code === code))
					.filter(Boolean);
				%>
				<p>
					<%= footer.legalLine %>
				</p>
				<div class="footer-bottom__meta">
					<a href="mailto:<%= site.email %>" data-ga-contact-method="email" data-ga-location="footer_legal"><%= site.email %></a>
					<span aria-hidden="true">/</span>
					<a href="<%= privacyPath %>"><%= privacyLabel %></a>
				</div>
				<div class="footer-bottom__langs" aria-label="<%= lang.langLabel %>">
					<% footerLangs.forEach((locale) => {
						const targetKey = pageKey || "home";
						const href = (locale.paths && locale.paths[targetKey]) || locale.paths.home;
						const activeClass = locale.code === lang.code ? " site-header__lang--active" : "";
						%>
						<a class="site-header__lang<%= activeClass %>" href="<%= href %>" data-lang="<%= locale.code %>" data-ga-language-switch="footer"><%= locale.labelShort %></a>
					<% }); %>
				</div>
			</div>
		</div>
	</footer>
	<% } %>

	<input class="cookie-notice__toggle" type="checkbox" id="cookie-notice-toggle" tabindex="-1">
	<label class="cookie-notice" for="cookie-notice-toggle" role="note" aria-label="<%= lang.cookieNotice.closeLabel %>">
		<span><%= lang.cookieNotice.text %></span>
		<span class="cookie-notice__close" aria-hidden="true">×</span>
	</label>

	<div class="cta-bar">
		<a class="button button--primary cta-bar__button" href="tel:<%= site.phone %>" aria-label="<%= lang.cta %>" data-ga-contact-method="call" data-ga-location="cta_bar">
			<img class="button__icon" src="/assets/icons/social/call.png" alt="" width="24" height="24">
		</a>
			<a class="button button--ghost cta-bar__button" href="https://wa.me/<%= site.phone.replace(/[^0-9]/g, '') %>"
				target="_blank" rel="noopener" aria-label="<%= lang.ctaMessage || lang.home?.ctaSecondary || 'WhatsApp' %>" data-ga-contact-method="whatsapp" data-ga-location="cta_bar">
				<img class="button__icon" src="/assets/icons/social/wh-1.png" alt="" width="24" height="24">
		</a>
		<a class="button button--ghost cta-bar__button" href="<%= site.viber %>" target="_blank" rel="noopener" aria-label="Viber" data-ga-contact-method="viber" data-ga-location="cta_bar">
			<img class="button__icon" src="/assets/icons/social/viber.png" alt="" width="24" height="24">
		</a>
		<a class="button button--ghost cta-bar__button" href="<%= site.telegram %>" target="_blank" rel="noopener" aria-label="Telegram" data-ga-contact-method="telegram" data-ga-location="cta_bar">
			<img class="button__icon" src="/assets/icons/social/tg.png" alt="" width="24" height="24">
		</a>
	</div>
	<script src="/assets/analytics.js"></script>
	<script>
		(function () {
			const setPrefLang = (code) => {
				document.cookie =
					"preferred_lang=" +
					encodeURIComponent(code) +
					";path=/;max-age=" +
					60 * 60 * 24 * 30 +
					";samesite=lax";
			};

			const links = document.querySelectorAll("[data-ga-language-switch]");
			links.forEach((link) => {
				link.addEventListener("click", () => {
					const code = link.dataset.lang || "";
					if (code) {
						setPrefLang(code);
					}
				});
			});
		})();
	</script>
</body>

</html>
