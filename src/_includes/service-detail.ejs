<section class="section section--surface">
  <div class="container">
    <div class="section__header">
      <h1 class="section__title">
        <%= page.heading %>
      </h1>
      <p class="section__lead">
        <%= page.lead %>
      </p>
      <% if (page.datePublished || page.dateModified) { %>
        <%
        const dateLabels = {
          ru: { published: "Опубликовано", modified: "Обновлено" },
          en: { published: "Published", modified: "Updated" },
          ka: { published: "გამოქვეყნდა", modified: "განახლდა" }
        };
        const currentDateLabels = dateLabels[lang.code] || dateLabels.en;
        %>
        <p class="section__meta">
          <% if (page.datePublished) { %>
            <span><%= currentDateLabels.published %>: <time datetime="<%= page.datePublished %>"><%= page.datePublished %></time></span>
          <% } %>
          <% if (page.dateModified) { %>
            <span><%= currentDateLabels.modified %>: <time datetime="<%= page.dateModified %>"><%= page.dateModified %></time></span>
          <% } %>
        </p>
      <% } %>
    </div>
  </div>
</section>

<% if (page.sections && page.sections.length) { %>
  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        <% page.sections.forEach((block) => { %>
          <div class="card">
            <h2 class="card__title"><%= block.title %></h2>
            <% if (block.lead) { %>
              <p class="card__text"><%= block.lead %></p>
            <% } %>
            <% if (block.items) { %>
              <ul class="list">
                <% block.items.forEach((item) => { %>
                  <li class="list__item">• <span><%= item %></span></li>
                <% }); %>
              </ul>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  </section>
<% } %>

<% if (page.diagnosisSteps && page.diagnosisSteps.items && page.diagnosisSteps.items.length) { %>
  <section class="section section--surface">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title"><%= page.diagnosisSteps.title %></h2>
        <% if (page.diagnosisSteps.lead) { %>
          <p class="section__lead"><%= page.diagnosisSteps.lead %></p>
        <% } %>
      </div>
      <div class="steps steps--compact">
        <% page.diagnosisSteps.items.forEach((item, index) => { %>
          <div class="steps__item">
            <div class="steps__index"><%= index + 1 %></div>
            <p class="steps__text"><%= item %></p>
          </div>
        <% }); %>
      </div>
    </div>
  </section>
<% } %>

<% if ((page.brandsHandled && page.brandsHandled.items && page.brandsHandled.items.length) || (page.trustSignals && page.trustSignals.items && page.trustSignals.items.length)) { %>
  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        <% if (page.brandsHandled && page.brandsHandled.items && page.brandsHandled.items.length) { %>
          <div class="card">
            <h2 class="card__title"><%= page.brandsHandled.title %></h2>
            <% if (page.brandsHandled.lead) { %>
              <p class="card__text"><%= page.brandsHandled.lead %></p>
            <% } %>
            <div class="badge-row">
              <% page.brandsHandled.items.forEach((brand) => { %>
                <span class="badge badge--outline"><%= brand %></span>
              <% }); %>
            </div>
          </div>
        <% } %>

        <% if (page.trustSignals && page.trustSignals.items && page.trustSignals.items.length) { %>
          <div class="card card--elevated">
            <h2 class="card__title"><%= page.trustSignals.title %></h2>
            <% if (page.trustSignals.lead) { %>
              <p class="card__text"><%= page.trustSignals.lead %></p>
            <% } %>
            <ul class="list">
              <% page.trustSignals.items.forEach((item) => { %>
                <li class="list__item">• <span><%= item %></span></li>
              <% }); %>
            </ul>
          </div>
        <% } %>
      </div>
    </div>
  </section>
<% } %>

<% if (page.caseStudies && page.caseStudies.items && page.caseStudies.items.length) { %>
  <section class="section section--surface">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title"><%= page.caseStudies.title %></h2>
        <% if (page.caseStudies.lead) { %>
          <p class="section__lead"><%= page.caseStudies.lead %></p>
        <% } %>
      </div>
      <div class="grid grid--3">
        <% page.caseStudies.items.forEach((item) => { %>
          <article class="card case-card">
            <h3 class="card__title"><%= item.title %></h3>
            <% if (item.appliance) { %>
              <p class="card__text"><strong><%= page.caseStudies.applianceLabel || "Appliance" %>:</strong> <%= item.appliance %></p>
            <% } %>
            <% if (item.symptom) { %>
              <p class="card__text"><strong><%= page.caseStudies.symptomLabel %>:</strong> <%= item.symptom %></p>
            <% } %>
            <% if (item.diagnosis) { %>
              <p class="card__text"><strong><%= page.caseStudies.diagnosisLabel || page.caseStudies.fixLabel %>:</strong> <%= item.diagnosis %></p>
            <% } %>
            <% if (item.workDone) { %>
              <p class="card__text"><strong><%= page.caseStudies.workDoneLabel || page.caseStudies.fixLabel %>:</strong> <%= item.workDone %></p>
            <% } %>
            <% if (item.result) { %>
              <p class="card__text"><strong><%= page.caseStudies.resultLabel || "Result" %>:</strong> <%= item.result %></p>
            <% } %>
            <% if (item.time) { %>
              <p class="card__text"><strong><%= page.caseStudies.timeLabel || "Time" %>:</strong> <%= item.time %></p>
            <% } %>
            <% if (item.priceHint) { %>
              <p class="card__text"><strong><%= page.caseStudies.priceHintLabel || "Price" %>:</strong> <%= item.priceHint %></p>
            <% } %>
            <% if (item.fix) { %>
              <p class="card__text"><strong><%= page.caseStudies.fixLabel %>:</strong> <%= item.fix %></p>
            <% } %>
            <% if (item.area) { %>
              <p class="card__text"><strong><%= page.caseStudies.areaLabel %>:</strong> <%= item.area %></p>
            <% } %>
          </article>
        <% }); %>
      </div>
    </div>
  </section>
<% } %>

<% if (page.photos && page.photos.items && page.photos.items.length) { %>
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title"><%= page.photos.title %></h2>
        <% if (page.photos.lead) { %>
          <p class="section__lead"><%= page.photos.lead %></p>
        <% } %>
      </div>
      <div class="grid grid--3">
        <% page.photos.items.forEach((item) => { %>
          <% if (item.src && item.alt) { %>
            <figure class="job-photo">
              <img src="<%= item.src %>" alt="<%= item.alt %>" loading="lazy" width="<%= item.width || 640 %>" height="<%= item.height || 480 %>">
              <% if (item.caption) { %>
                <figcaption><%= item.caption %></figcaption>
              <% } %>
            </figure>
          <% } %>
        <% }); %>
      </div>
    </div>
  </section>
<% } %>

<% if (page.price && ((page.price.items && page.price.items.length) || (page.price.groups && page.price.groups.length))) { %>
  <section class="section section--surface" id="price">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title"><%= page.price.title %></h2>
        <% if (page.price.lead) { %>
          <p class="section__lead"><%= page.price.lead %></p>
        <% } %>
      </div>
      <% if (page.price.items && page.price.items.length) { %>
        <ul class="price-list">
          <% page.price.items.forEach((item) => { %>
            <li class="price-list__item">
              <strong><%= item.label %></strong>
              <span><%= item.value %></span>
            </li>
          <% }); %>
        </ul>
      <% } %>
      <% if (page.price.groups && page.price.groups.length) { %>
        <div class="price-groups">
          <% page.price.groups.forEach((group) => { %>
            <section class="price-group">
              <h3 class="price-group__title"><%= group.title %></h3>
              <% if (group.lead) { %>
                <p class="card__text"><%= group.lead %></p>
              <% } %>
              <ul class="price-list">
                <% group.items.forEach((item) => { %>
                  <li class="price-list__item">
                    <strong><%= item.label %></strong>
                    <span><%= item.value %></span>
                  </li>
                <% }); %>
              </ul>
            </section>
          <% }); %>
        </div>
      <% } %>
      <% if (page.price.note) { %>
        <div class="card card--elevated">
          <p class="card__text"><%= page.price.note %></p>
        </div>
      <% } %>
    </div>
  </section>
<% } %>

<% if (page.faq && page.faq.items && page.faq.items.length) { %>
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title"><%= page.faq.title %></h2>
        <% if (page.faq.lead) { %>
          <p class="section__lead"><%= page.faq.lead %></p>
        <% } %>
      </div>
      <% page.faq.items.forEach((item, index) => { %>
        <details class="faq" data-ga-faq-scope="page" data-ga-faq-index="<%= index + 1 %>">
          <summary class="faq__summary"><%= item.question %></summary>
          <div class="faq__content"><%= item.answer %></div>
        </details>
      <% }); %>
    </div>
  </section>
<% } %>

<% if (page.related && page.related.items && page.related.items.length) { %>
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title"><%= page.related.title %></h2>
        <% if (page.related.lead) { %>
          <p class="section__lead"><%= page.related.lead %></p>
        <% } %>
      </div>
      <div class="grid grid--3">
        <% page.related.items.forEach((item)=> { %>
          <article class="card">
            <h3 class="card__title"><%= item.title %></h3>
            <% if (item.text) { %>
              <p class="card__text"><%= item.text %></p>
            <% } %>
            <a class="card__link" href="<%= lang.paths[item.key] %>" data-ga-content-type="related_link" data-ga-destination-key="<%= item.key %>" data-ga-location="page_related">
              <%= item.linkLabel || page.related.linkLabel || lang.home?.guides?.linkLabel || lang.common.moreDetails %>
            </a>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
<% } %>

<%- include("./search-phrases.ejs", { searchPhrases: page.searchPhrases, lang, linkItems: true, trackingLocation: "page_search_phrases", trackingContentType: "search_phrase" }) %>

<% if (page.cta) { %>
  <section class="section section--surface">
    <div class="container">
      <div class="cta-section">
        <h2 class="card__title"><%= page.cta.title %></h2>
        <p class="card__text"><%= page.cta.text %></p>
        <div class="section__actions">
          <a class="button button--primary" href="tel:<%= site.phone %>" data-ga-contact-method="call" data-ga-location="page_cta">
            <%= page.cta.button || lang.cta %>
          </a>
          <a class="button button--ghost" href="https://wa.me/<%= site.phone.replace(/[^0-9]/g, '') %>" target="_blank" rel="noopener" data-ga-contact-method="whatsapp" data-ga-location="page_cta">
            <img class="button__icon" src="/assets/icons/social/wh-1.png" alt="WhatsApp icon" width="24" height="24">
            <%= lang.ctaMessage || "WhatsApp" %>
          </a>
          <a class="button button--ghost" href="<%= site.viber %>" target="_blank" rel="noopener" data-ga-contact-method="viber" data-ga-location="page_cta">
            <img class="button__icon" src="/assets/icons/social/viber.png" alt="Viber icon" width="24" height="24">
            Viber
          </a>
          <% if (site.telegram) { %>
            <a class="button button--ghost" href="<%= site.telegram %>" target="_blank" rel="noopener" data-ga-contact-method="telegram" data-ga-location="page_cta">
              <img class="button__icon" src="/assets/icons/social/tg.png" alt="Telegram icon" width="24" height="24">
              Telegram
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </section>
<% } %>
