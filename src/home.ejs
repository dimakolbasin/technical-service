<section class="section hero section--surface">
  <div class="container hero__layout">
    <div class="hero__content">
      <h1 class="hero__title">
        <%= lang.home.title %>
      </h1>
      <p class="hero__lead">
        <%= lang.home.lead %>
      </p>
      <% if (lang.home.areaNote) { %>
        <p class="hero__lead">
          <%= lang.home.areaNote %>
        </p>
        <% } %>
          <% if (lang.home.chips) { %>
            <div class="hero__chips">
              <% lang.home.chips.forEach((chip)=> { %>
                <span class="badge badge--outline">
                  <%= chip %>
                </span>
                <% }) %>
            </div>
            <% } %>
              <div class="hero__actions">
                <a class="button button--primary" href="tel:<%= site.phone %>" data-ga-contact-method="call" data-ga-location="home_hero">
                  <%= lang.home.ctaPrimary %>
                </a>
                <a class="button button--ghost" href="https://wa.me/<%= site.phone.replace(/[^0-9]/g, '') %>" target="_blank"
                  rel="noopener" data-ga-contact-method="whatsapp" data-ga-location="home_hero">
                  <img class="button__icon" src="/assets/icons/social/wh-1.png" alt="WhatsApp icon" width="24" height="24">
                  <%= lang.ctaMessage || lang.home.ctaSecondary || "WhatsApp" %>
                </a>
                <a class="button button--ghost" href="<%= site.viber %>" target="_blank" rel="noopener" data-ga-contact-method="viber" data-ga-location="home_hero">
                  <img class="button__icon" src="/assets/icons/social/viber.png" alt="Viber icon" width="24" height="24">
                  Viber
                </a>
                <a class="button button--ghost" href="<%= site.telegram %>" target="_blank" rel="noopener" data-ga-contact-method="telegram" data-ga-location="home_hero">
                  <img class="button__icon" src="/assets/icons/social/tg.png" alt="Telegram icon" width="24" height="24">
                  Telegram
                </a>
                <% if (site.facebook) { %>
                  <a class="button button--ghost" href="<%= site.facebook %>" target="_blank" rel="noopener" data-ga-contact-method="facebook" data-ga-location="home_hero">
                    <img class="button__icon" src="/assets/icons/social/fb.png" alt="Facebook icon" width="24" height="24">
                    Facebook
                  </a>
                  <% } %>
              </div>
              <% if (lang.home.heroNote) { %>
                <p class="hero__note">
                  <%= lang.home.heroNote %>
                </p>
                <% } %>
    </div>
    <figure class="hero__media" aria-hidden="true">
      <picture>
        <source srcset="/assets/images/hero-appliances-desktop.webp" media="(min-width: 720px)" type="image/webp">
        <img src="/assets/images/hero-appliances-mobile.webp" alt="" width="1767" height="890" fetchpriority="high">
      </picture>
    </figure>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">
        <%= lang.home.services.title %>
      </h2>
      <p class="section__lead">
        <%= lang.home.services.lead %>
      </p>
      <% if (lang.home.services.ctaToPrices) { %>
        <div class="section__actions">
          <a class="button button--ghost" href="<%= lang.paths.prices %>" data-ga-content-type="section_cta" data-ga-destination-key="prices" data-ga-location="home_services">
            <%= lang.home.services.ctaToPrices %>
          </a>
        </div>
        <% } %>
    </div>
    <div class="grid grid--3 service-grid">
      <% lang.home.services.items.forEach((item)=> {
        const highlight = item.highlight ? " card--elevated" : "";
        const iconFile = item.serviceIcon || null;
        const iconSrc = iconFile ? `/assets/icons/services/${iconFile}` : (item.icon ? `/assets/icons/${item.icon}` : "/assets/icons/icon-tools.png");
        const serviceHref = item.linkKey && lang.paths[item.linkKey] ? `${lang.paths[item.linkKey]}#price` : lang.paths[lang.home.services.linkKey];
        %>
        <article class="card service-card<%= highlight %>">
          <% if (iconSrc) { %>
            <span class="card__icon" aria-hidden="true">
              <img src="<%= iconSrc %>" alt="<%= item.title %> icon" width="24" height="24">
            </span>
            <% } else { %>
              <span class="card__icon card__icon--placeholder" aria-hidden="true">🛈</span>
              <% } %>
                <h3 class="card__title">
                  <%= item.title %>
                </h3>
                <p class="card__text">
                  <%= item.text %>
                </p>
                <a class="card__link" href="<%= serviceHref %>" style="margin-top: 16px; display: inline-block;" data-ga-content-type="service_card" data-ga-destination-key="<%= item.linkKey || lang.home.services.linkKey %>" data-ga-location="home_services">
                  <%= lang.home.services.linkLabel %>
                    <%= item.title %>
                </a>
        </article>
        <% }) %>
    </div>
  </div>
</section>

<% if (lang.home.brands) { %>
  <section class="section section--brands">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">
          <%= lang.home.brands.title %>
        </h2>
        <% if (lang.home.brands.lead) { %>
          <p class="section__lead">
            <%= lang.home.brands.lead %>
          </p>
          <% } %>
      </div>
      <div class="badge-row">
        <% lang.home.brands.items.forEach((brand)=> { %>
          <span class="badge badge--outline">
            <%= brand %>
          </span>
          <% }) %>
      </div>
    </div>
  </section>
  <% } %>

            <section class="section section--surface section--benefits">
              <div class="container">
                <div class="section__header">
                  <h2 class="section__title">
                    <%= lang.home.benefits.title %>
                  </h2>
                  <p class="section__lead">
                    <%= lang.home.benefits.lead %>
                  </p>
                </div>
                <div class="grid grid--3">
                  <% lang.home.benefits.items.forEach((item)=> { %>
                    <div class="card benefit-card">
                      <h3 class="card__title">
                        <%= item.title %>
                      </h3>
                      <p class="card__text">
                        <%= item.text %>
                      </p>
                    </div>
                    <% }) %>
                </div>
              </div>
            </section>

            <section class="section section--steps">
              <div class="container">
                <div class="section__header">
                  <h2 class="section__title">
                    <%= lang.home.steps.title %>
                  </h2>
                  <p class="section__lead">
                    <%= lang.home.steps.lead %>
                  </p>
                </div>
                <div class="steps">
                  <% lang.home.steps.items.forEach((item, index)=> { %>
                    <div class="steps__item">
                      <div class="steps__index">
                        <%= index + 1 %>
                      </div>
                      <p class="steps__text">
                        <%= item %>
                      </p>
                    </div>
                    <% }) %>
                </div>
              </div>
            </section>

    <% if (lang.home.guides) { %>
      <section class="section section--surface">
        <div class="container">
          <div class="section__header">
            <h2 class="section__title">
              <%= lang.home.guides.title %>
            </h2>
            <% if (lang.home.guides.lead) { %>
              <p class="section__lead">
                <%= lang.home.guides.lead %>
              </p>
              <% } %>
          </div>
          <div class="grid grid--3">
            <% lang.home.guides.items.forEach((item)=> { %>
              <article class="card guide-card">
                <h3 class="card__title">
                  <%= item.title %>
                </h3>
                <% if (item.text) { %>
                  <p class="card__text">
                    <%= item.text %>
                  </p>
                  <% } %>
                    <% const guideLinkLabel=item.linkLabel || lang.home.guides.linkLabel; %>
                      <a class="card__link" href="<%= lang.paths[item.key] %>" data-ga-content-type="guide_card" data-ga-destination-key="<%= item.key %>" data-ga-location="home_guides">
                        <%= guideLinkLabel %> — <%= item.title %>
                      </a>
              </article>
              <% }) %>
          </div>
        </div>
      </section>
      <% } %>

            <section class="section section--surface section--prices" id="prices">
              <div class="container">
                <div class="section__header">
                  <h2 class="section__title">
                    <%= lang.home.prices.title %>
                  </h2>
                  <p class="section__lead">
                    <%= lang.home.prices.lead %>
                  </p>
                </div>
                <div class="price-panel">
                  <ul class="price-list">
                    <% lang.home.prices.items.forEach((item)=> { %>
                      <li class="price-list__item">
                        <strong>
                          <%= item.label %>
                        </strong>
                        <span>
                          <%= item.value %>
                        </span>
                      </li>
                      <% }) %>
                  </ul>
                </div>
              </div>
            </section>

            <% const serviceStandard = lang.home.serviceStandard; %>
            <% const serviceStandardContent = serviceStandard && serviceStandard.content ? serviceStandard.content : null; %>
            <% const serviceStandardSections = serviceStandardContent && serviceStandardContent.sections ? serviceStandardContent.sections : []; %>
            <% const serviceStandardFacts = serviceStandardSections.reduce((facts, section) => {
              const firstItem = (section.list || [])[0];
              if (firstItem) {
                facts.push({ group: section.title, text: firstItem });
              }
              return facts;
            }, []); %>
            <% if (serviceStandardSections[1] && serviceStandardSections[1].list && serviceStandardSections[1].list[1]) {
              serviceStandardFacts.push({ group: serviceStandardSections[1].title, text: serviceStandardSections[1].list[1] });
            } %>
            <% const visibleServiceStandardFacts = serviceStandardFacts.slice(0, 3); %>
            <% if (serviceStandard && serviceStandardContent) { %>
              <section class="section section--surface section--service-standard">
                <div class="container">
                  <div class="service-standard">
                    <div class="service-standard__media" aria-hidden="true">
                      <picture>
                        <source srcset="/assets/images/service-work-1-mobile.webp" media="(max-width: 719px)" type="image/webp">
                        <img class="service-standard__photo service-standard__photo--main" src="/assets/images/service-work-1.webp" alt="" width="1024" height="682" loading="lazy">
                      </picture>
                      <picture>
                        <source srcset="/assets/images/service-work-2-mobile.webp" media="(max-width: 719px)" type="image/webp">
                        <img class="service-standard__photo service-standard__photo--detail" src="/assets/images/service-work-2.webp" alt="" width="1024" height="682" loading="lazy">
                      </picture>
                    </div>
                    <div class="service-standard__content">
                      <p class="service-standard__eyebrow">
                        <%= serviceStandard.title %>
                      </p>
                      <h2 class="section__title">
                        <%= serviceStandardContent.subtitle || serviceStandard.title %>
                      </h2>
                      <p class="section__lead">
                        <%= serviceStandard.lead %>
                      </p>
                      <p class="service-standard__intro">
                        <%= serviceStandardContent.intro %>
                      </p>
                      <% if (visibleServiceStandardFacts.length) { %>
                        <div class="service-standard__facts">
                          <% visibleServiceStandardFacts.forEach((fact)=> { %>
                            <article class="service-standard__fact">
                              <span class="service-standard__fact-label">
                                <%= fact.group.replace(/:$/, "") %>
                              </span>
                              <p>
                                <%- fact.text %>
                              </p>
                            </article>
                            <% }) %>
                        </div>
                        <% } %>
                      <div class="section__actions">
                        <a class="button button--primary" href="tel:<%= site.phone %>" data-ga-contact-method="call" data-ga-location="home_service_standard">
                          <%= lang.home.ctaPrimary %>
                        </a>
                        <a class="button button--ghost" href="<%= lang.paths.contacts %>" data-ga-content-type="section_cta" data-ga-destination-key="contacts" data-ga-location="home_service_standard">
                          <%= lang.nav.find((item) => item.key === "contacts")?.label || "Contacts" %>
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              </section>
              <% } %>

                <% const reviewsTitle=lang.home.reviews?.title || "" ; const reviewsLead=lang.home.reviews?.lead
                      || "" ; const reviewItems=lang.home.reviews?.items?.length ? lang.home.reviews.items.slice(0, 5) :
                      []; %>
                      <section class="section section--surface">
                        <div class="container">
                          <div class="section__header">
                            <h2 class="section__title">
                              <%= reviewsTitle %>
                            </h2>
                            <p class="section__lead">
                              <%= reviewsLead %>
                            </p>
                          </div>
                          <div class="grid grid--3">
                            <% reviewItems.forEach((item, index)=> { %>
                              <article class="card review-card">
                                <div class="review-card__head">
                                  <img class="review-card__avatar" src="/assets/users/user-<%= index + 1 %>.png"
                                    alt="<%= lang.home.reviews.avatarAlt.replace('{name}', item.name) %>" width="48" height="48" loading="lazy">
                                  <div>
                                    <p class="review-card__name">
                                      <%= item.name %>
                                    </p>
                                    <p class="review-card__stars" aria-label="<%= lang.home.reviews.ratingLabel %>">★★★★★</p>
                                  </div>
                                </div>
                                <p class="review-card__text">
                                  <%= item.text %>
                                </p>
                              </article>
                              <% }) %>
                          </div>
                        </div>

                      </section>

                      <% if (lang.home.faq && lang.home.faq.items && lang.home.faq.items.length) { %>
                        <section class="section">
                          <div class="container">
                            <div class="section__header">
                              <h2 class="section__title">
                                <%= lang.home.faq.title %>
                              </h2>
                              <p class="section__lead">
                                <%= lang.home.faq.lead %>
                              </p>
                            </div>
                            <% lang.home.faq.items.forEach((item, index)=> { %>
                              <details class="faq" data-ga-faq-scope="home" data-ga-faq-index="<%= index + 1 %>">
                                <summary class="faq__summary">
                                  <%= item.question %>
                                </summary>
                                <div class="faq__content">
                                  <%= item.answer %>
                                </div>
                              </details>
                              <% }) %>
                          </div>
                        </section>
                        <% } %>
