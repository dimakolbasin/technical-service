<section class="section hero section--surface">
  <div class="container hero__layout">
    <div class="hero__content">
      <h1 class="hero__title">
        <%= lang.home.title %>
      </h1>
      <p class="hero__lead">
        <%= lang.home.lead %>
      </p>
      <% if (lang.home.areaNote) { %>
        <p class="hero__lead">
          <%= lang.home.areaNote %>
        </p>
        <% } %>
          <% if (lang.home.chips) { %>
            <div class="hero__chips">
              <% lang.home.chips.forEach((chip)=> { %>
                <span class="badge badge--outline">
                  <%= chip %>
                </span>
                <% }) %>
            </div>
            <% } %>
              <div class="hero__actions">
                <a class="button button--primary" href="tel:<%= site.phone %>">
                  <%= lang.home.ctaPrimary %>
                </a>
                <a class="button button--secondary" href="https://wa.me/<%= site.phone.replace(/[^0-9]/g, '') %>" target="_blank"
                  rel="noopener">
                  <img class="button__icon" src="/assets/icons/social/wh.png" alt="WhatsApp icon" width="24" height="24">
                  <%= lang.ctaMessage || lang.home.ctaSecondary || "WhatsApp" %>
                </a>
                <a class="button button--ghost" href="<%= site.viber %>" target="_blank" rel="noopener">
                  <img class="button__icon" src="/assets/icons/social/viber.png" alt="Viber icon" width="24" height="24">
                  Viber
                </a>
                <a class="button button--ghost" href="<%= site.telegram %>" target="_blank" rel="noopener">
                  <img class="button__icon" src="/assets/icons/social/tg.png" alt="Telegram icon" width="24" height="24">
                  Telegram
                </a>
                <% if (site.facebook) { %>
                  <a class="button button--ghost" href="<%= site.facebook %>" target="_blank" rel="noopener">
                    <img class="button__icon" src="/assets/icons/social/fb.png" alt="Facebook icon" width="24" height="24">
                    Facebook
                  </a>
                  <% } %>
              </div>
              <% if (lang.home.heroNote) { %>
                <p class="hero__note">
                  <%= lang.home.heroNote %>
                </p>
                <% } %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">
        <%= lang.home.services.title %>
      </h2>
      <p class="section__lead">
        <%= lang.home.services.lead %>
      </p>
      <% if (lang.home.services.ctaToPrices) { %>
        <div class="section__actions">
          <a class="button button--ghost" href="<%= lang.paths.prices %>">
            <%= lang.home.services.ctaToPrices %>
          </a>
        </div>
        <% } %>
    </div>
    <div class="grid grid--3">
      <% lang.home.services.items.forEach((item)=> {
        const highlight = item.highlight ? " card--elevated" : "";
        const iconFile = item.serviceIcon || null;
        const iconSrc = iconFile ? `/assets/icons/services/${iconFile}` : null;
        const serviceHref = item.linkKey && lang.paths[item.linkKey] ? lang.paths[item.linkKey] : lang.paths[lang.home.services.linkKey];
        %>
        <article class="card<%= highlight %>">
          <% if (iconSrc) { %>
            <span class="card__icon" aria-hidden="true">
              <img src="<%= iconSrc %>" alt="<%= item.title %> icon" width="24" height="24">
            </span>
            <% } else { %>
              <span class="card__icon card__icon--placeholder" aria-hidden="true">🛈</span>
              <% } %>
                <h3 class="card__title">
                  <%= item.title %>
                </h3>
                <p class="card__text">
                  <%= item.text %>
                </p>
                <a class="card__link" href="<%= serviceHref %>" style="margin-top: 16px; display: inline-block;">
                  <%= lang.home.services.linkLabel %>
                    <%= item.title %>
                </a>
        </article>
        <% }) %>
    </div>
  </div>
</section>

<% if (lang.home.brands) { %>
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2 class="section__title">
          <%= lang.home.brands.title %>
        </h2>
        <% if (lang.home.brands.lead) { %>
          <p class="section__lead">
            <%= lang.home.brands.lead %>
          </p>
          <% } %>
      </div>
      <div class="badge-row">
        <% lang.home.brands.items.forEach((brand)=> { %>
          <span class="badge badge--outline">
            <%= brand %>
          </span>
          <% }) %>
      </div>
    </div>
  </section>
  <% } %>

    <% if (lang.home.guides) { %>
      <section class="section section--surface">
        <div class="container">
          <div class="section__header">
            <h2 class="section__title">
              <%= lang.home.guides.title %>
            </h2>
            <% if (lang.home.guides.lead) { %>
              <p class="section__lead">
                <%= lang.home.guides.lead %>
              </p>
              <% } %>
          </div>
          <div class="grid grid--3">
            <% lang.home.guides.items.forEach((item)=> { %>
              <article class="card">
                <h3 class="card__title">
                  <%= item.title %>
                </h3>
                <% if (item.text) { %>
                  <p class="card__text">
                    <%= item.text %>
                  </p>
                  <% } %>
                    <% const guideLinkLabel=item.linkLabel || lang.home.guides.linkLabel; %>
                      <a class="card__link" href="<%= lang.paths[item.key] %>">
                        <%= guideLinkLabel %> — <%= item.title %>
                      </a>
              </article>
              <% }) %>
          </div>
        </div>
      </section>
      <% } %>

            <section class="section section--surface" id="prices">
              <div class="container">
                <div class="section__header">
                  <h2 class="section__title">
                    <%= lang.home.prices.title %>
                  </h2>
                  <p class="section__lead">
                    <%= lang.home.prices.lead %>
                  </p>
                </div>
                <ul class="price-list">
                  <% lang.home.prices.items.forEach((item)=> { %>
                    <li class="price-list__item">
                      <strong>
                        <%= item.label %>
                      </strong>
                      <span>
                        <%= item.value %>
                      </span>
                    </li>
                    <% }) %>
                </ul>
              </div>
            </section>

            <section class="section section--surface">
              <div class="container">
                <div class="section__header">
                  <h2 class="section__title">
                    <%= lang.home.benefits.title %>
                  </h2>
                  <p class="section__lead">
                    <%= lang.home.benefits.lead %>
                  </p>
                </div>
                <div class="grid grid--3">
                  <% lang.home.benefits.items.forEach((item)=> { %>
                    <div class="card">
                      <h3 class="card__title">
                        <%= item.title %>
                      </h3>
                      <p class="card__text">
                        <%= item.text %>
                      </p>
                    </div>
                    <% }) %>
                </div>
              </div>
            </section>

            <section class="section">
              <div class="container">
                <div class="section__header">
                  <h2 class="section__title">
                    <%= lang.home.steps.title %>
                  </h2>
                  <p class="section__lead">
                    <%= lang.home.steps.lead %>
                  </p>
                </div>
                <div class="steps">
                  <% lang.home.steps.items.forEach((item, index)=> { %>
                    <div class="steps__item">
                      <div class="steps__index">
                        <%= index + 1 %>
                      </div>
                      <p class="steps__text">
                        <%= item %>
                      </p>
                    </div>
                    <% }) %>
                </div>
              </div>
            </section>

            <% if (lang.home.aboutSnippet) { %>
              <section class="section section--surface">
                <div class="container">
                  <div class="section__header">
                    <h2 class="section__title">
                      <%= lang.home.aboutSnippet.title %>
                    </h2>
                    <p class="section__lead">
                      <%= lang.home.aboutSnippet.lead %>
                    </p>
                  </div>
                  <% if (lang.home.aboutSnippet.pillars) { %>
                    <div class="grid grid--3">
                      <% lang.home.aboutSnippet.pillars.forEach((pillar)=> { %>
                        <div class="card">
                          <h3 class="card__title">
                            <%= pillar.title %>
                          </h3>
                          <p class="card__text">
                            <%= pillar.text %>
                          </p>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>
                      <div class="section__actions">
                        <a class="button button--ghost" href="<%= lang.paths.about %>">
                          <%= lang.pages.about.heading %>
                        </a>
                      </div>
                </div>
              </section>
              <% } %>

                <% const reviewsTitle=lang.home.reviews?.title || "" ; const reviewsLead=lang.home.reviews?.lead
                      || "" ; const reviewItems=lang.home.reviews?.items?.length ? lang.home.reviews.items.slice(0, 5) :
                      []; %>
                      <section class="section section--surface">
                        <div class="container">
                          <div class="section__header">
                            <h2 class="section__title">
                              <%= reviewsTitle %>
                            </h2>
                            <p class="section__lead">
                              <%= reviewsLead %>
                            </p>
                          </div>
                          <div class="grid grid--3">
                            <% reviewItems.forEach((item, index)=> { %>
                              <article class="card review-card">
                                <div class="review-card__head">
                                  <img class="review-card__avatar" src="/assets/users/user-<%= index + 1 %>.png"
                                    alt="Фото клиента <%= item.name %>" width="48" height="48" loading="lazy">
                                  <div>
                                    <p class="review-card__name">
                                      <%= item.name %>
                                    </p>
                                    <p class="review-card__stars" aria-label="Рейтинг 5 из 5">★★★★★</p>
                                  </div>
                                </div>
                                <p class="review-card__text">
                                  <%= item.text %>
                                </p>
                              </article>
                              <% }) %>
                          </div>
                        </div>

                        <% if (lang.home.reviewForm) { %>
                          <div class="container" style="margin-top: 48px; max-width: 600px;">
                            <div class="card card--elevated">
                              <h3 class="card__title">
                                <%= lang.home.reviewForm.title %>
                              </h3>
                              <p class="card__text">
                                <%= lang.home.reviewForm.lead %>
                              </p>
                              <form class="form" action="https://api.web3forms.com/submit" method="POST"
                                autocomplete="off">
                                <input type="hidden" name="access_key" value="<%= site.web3formsAccessKey %>">
                                <input type="hidden" name="subject" value="New Review from Site">
                                <input type="hidden" name="from_name" value="Technic Service Reviews">

                                <div class="form__row">
                                  <label class="form__label" for="review-name">
                                    <%= lang.home.reviewForm.nameLabel %>
                                  </label>
                                  <input autocomplete="off" class="form__input" type="text" id="review-name" name="name"
                                    placeholder="<%= lang.home.reviewForm.namePlaceholder %>" required>
                                </div>
                                <div class="form__row">
                                  <label class="form__label" for="review-text">
                                    <%= lang.home.reviewForm.textLabel %>
                                  </label>
                                  <textarea class="form__input" id="review-text" name="message" rows="4"
                                    placeholder="<%= lang.home.reviewForm.textPlaceholder %>" required></textarea>
                                </div>
                                <div class="form__actions">
                                  <button class="button button--primary" type="submit">
                                    <%= lang.home.reviewForm.submit %>
                                  </button>
                                </div>
                              </form>
                            </div>
                          </div>
                          <% } %>
                      </section>

                      <% if (lang.home.faq && lang.home.faq.items && lang.home.faq.items.length) { %>
                        <section class="section">
                          <div class="container">
                            <div class="section__header">
                              <h2 class="section__title">
                                <%= lang.home.faq.title %>
                              </h2>
                              <p class="section__lead">
                                <%= lang.home.faq.lead %>
                              </p>
                            </div>
                            <% lang.home.faq.items.forEach((item)=> { %>
                              <details class="faq">
                                <summary class="faq__summary">
                                  <%= item.question %>
                                </summary>
                                <div class="faq__content">
                                  <%= item.answer %>
                                </div>
                              </details>
                              <% }) %>
                          </div>
                        </section>
                        <% } %>

                          <section class="section section--surface">
                            <div class="container">
                              <div class="section__header">
                                <h2 class="section__title">
                                  <%= lang.home.contact.title %>
                                </h2>
                                <p class="section__lead">
                                  <%= lang.home.contact.lead %>
                                </p>
                              </div>
                              <div class="contact-card">
                                <div>
                                  <ul class="list">
                                    <% lang.home.contact.list.forEach((item)=> {
                                      const type = item.type;
                                      const waNumber = site.phone.replace(/[^0-9]/g, '');
                                      %>
                                      <li class="list__item">
                                        <strong>
                                          <%= item.label %>:
                                        </strong>
                                        <% if (type==="phone" ) { %>
                                          <a href="tel:<%= site.phone %>">
                                            <%= site.phone %>
                                          </a>
                                          <% } else if (type==="messengers" ) { %>
                                            <div class="messenger-row">
                                              <a class="card__icon card__icon--social" href="<%= site.telegram %>"
                                                target="_blank" rel="noopener" aria-label="Telegram">
                                                <img src="/assets/icons/social/tg.png" alt="Telegram icon" width="24"
                                                  height="24">
                                              </a>
                                              <a class="card__icon card__icon--social"
                                                href="https://wa.me/<%= waNumber %>" target="_blank" rel="noopener"
                                                aria-label="WhatsApp">
                                                <img src="/assets/icons/social/wh.png" alt="WhatsApp icon" width="24"
                                                  height="24">
                                              </a>
                                              <a class="card__icon card__icon--social" href="<%= site.viber %>"
                                                target="_blank" rel="noopener" aria-label="Viber">
                                                <img src="/assets/icons/social/viber.png" alt="Viber icon" width="24"
                                                  height="24">
                                              </a>
                                              <% if (site.facebook) { %>
                                                <a class="card__icon card__icon--social" href="<%= site.facebook %>"
                                                  target="_blank" rel="noopener" aria-label="Facebook">
                                                  <img src="/assets/icons/social/fb.png" alt="Facebook icon" width="24"
                                                    height="24">
                                                </a>
                                                <% } %>
                                            </div>
                                            <% } else if (type==="email" ) { %>
                                              <a href="mailto:<%= site.email %>">
                                                <%= site.email %>
                                              </a>
                                              <% } else { %>
                                                <span>
                                                  <%= item.value %>
                                                </span>
                                                <% } %>
                                      </li>
                                      <% }) %>
                                  </ul>
                                </div>
                              </div>
                            </div>
                          </section>
