<%
const contactPage = lang.pages.contacts;
const contactCards = Array.isArray(contactPage.cards) ? contactPage.cards : [];
const allContactItems = contactCards.flatMap((card) => card.items || []);
const findContactValue = (type) => (allContactItems.find((item) => item.type === type) || {}).value || "";
const address = site.address || {};
const addressLine = [address.street, address.locality, address.region, address.postalCode, address.country].filter(Boolean).join(", ");
const serviceArea = contactPage.businessInfo?.area || findContactValue("area") || (Array.isArray(lang.areasList) ? lang.areasList.join(", ") : "");
const workHours = contactPage.businessInfo?.hours || findContactValue("hours") || lang.hours;
const waNumber = site.phone.replace(/[^0-9]/g, "");
const mapLinks = [
  site.googleMaps ? { label: contactPage.map?.googleLabel || "Google Maps", href: site.googleMaps } : null,
  site.googleBusinessProfile ? { label: contactPage.map?.profileLabel || "Google Business Profile", href: site.googleBusinessProfile } : null
].filter(Boolean)
  .filter((link, index, links) => links.findIndex((candidate) => candidate.href === link.href) === index);
const googleMapEmbed = site.googleMapsEmbed || "";
const envTrustFacts = [
  site.trustFacts?.yearsInBusiness ? { label: contactPage.trustLabels?.years || "Years in business", value: site.trustFacts.yearsInBusiness } : null,
  site.trustFacts?.completedRepairs ? { label: contactPage.trustLabels?.repairs || "Completed repairs", value: site.trustFacts.completedRepairs } : null,
  site.trustFacts?.reviewSource ? { label: contactPage.trustLabels?.reviews || "Verified reviews", value: contactPage.trustLabels?.reviewsLink || "Review source", href: site.googleMaps } : null
].filter(Boolean);
const trustSignals = [
  ...(Array.isArray(contactPage.trustSignals) ? contactPage.trustSignals : []),
  ...envTrustFacts
];
%>

<section class="section section--surface">
  <div class="container">
    <div class="section__header">
      <h1 class="section__title">
        <%= contactPage.heading %>
      </h1>
      <p class="section__lead">
        <%= contactPage.lead %>
      </p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="contact-layout">
      <section class="card contact-nap" aria-labelledby="contact-nap-title">
        <h2 class="card__title" id="contact-nap-title">
          <%= contactPage.businessInfo?.title || site.name %>
        </h2>
        <ul class="list">
          <li class="list__item">
            <strong><%= contactPage.businessInfo?.nameLabel || "Business" %>:</strong>
            <span><%= site.name %></span>
          </li>
          <li class="list__item">
            <strong><%= contactPage.businessInfo?.phoneLabel || "Phone" %>:</strong>
            <a href="tel:<%= site.phone %>" data-ga-contact-method="call" data-ga-location="contacts_nap"><%= site.phone %></a>
          </li>
          <% if (site.email) { %>
            <li class="list__item">
              <strong><%= contactPage.businessInfo?.emailLabel || "Email" %>:</strong>
              <a href="mailto:<%= site.email %>" data-ga-contact-method="email" data-ga-location="contacts_nap"><%= site.email %></a>
            </li>
          <% } %>
          <% if (workHours) { %>
            <li class="list__item">
              <strong><%= contactPage.businessInfo?.hoursLabel || "Hours" %>:</strong>
              <span><%= workHours %></span>
            </li>
          <% } %>
          <% if (addressLine) { %>
            <li class="list__item">
              <strong><%= contactPage.businessInfo?.addressLabel || "Address" %>:</strong>
              <span><%= addressLine %></span>
            </li>
          <% } %>
          <% if (serviceArea) { %>
            <li class="list__item">
              <strong><%= contactPage.businessInfo?.areaLabel || "Service area" %>:</strong>
              <span><%= serviceArea %></span>
            </li>
          <% } %>
        </ul>
        <% if (contactPage.businessInfo?.note) { %>
          <p class="card__text"><%= contactPage.businessInfo.note %></p>
        <% } %>
      </section>

      <% if (mapLinks.length) { %>
        <section class="card contact-map" aria-labelledby="contact-map-title">
          <h2 class="card__title" id="contact-map-title">
            <%= contactPage.map?.title || "Map" %>
          </h2>
          <% if (contactPage.map?.lead) { %>
            <p class="card__text"><%= contactPage.map.lead %></p>
          <% } %>
          <% if (googleMapEmbed) { %>
            <div class="map-embed">
              <iframe
                src="<%= googleMapEmbed %>"
                title="<%= contactPage.map?.iframeTitle || contactPage.map?.title || 'Map' %>"
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
          <% } %>
          <div class="section__actions">
            <% mapLinks.forEach((link) => { %>
              <a class="button button--ghost" href="<%= link.href %>" target="_blank" rel="noopener" data-ga-content-type="map_link" data-ga-location="contacts_map">
                <%= link.label %>
              </a>
            <% }); %>
          </div>
        </section>
      <% } %>

      <% if (trustSignals.length) { %>
        <section class="card contact-trust" aria-labelledby="contact-trust-title">
          <h2 class="card__title" id="contact-trust-title">
            <%= contactPage.trustTitle || "" %>
          </h2>
          <div class="fact-grid">
            <% trustSignals.forEach((item) => { %>
              <article class="fact">
                <strong><%= item.label %></strong>
                <% if (item.href) { %>
                  <a href="<%= item.href %>" target="_blank" rel="noopener"><%= item.value %></a>
                <% } else { %>
                  <span><%= item.value || item.text %></span>
                <% } %>
              </article>
            <% }); %>
          </div>
        </section>
      <% } %>
    </div>
  </div>
</section>

<section class="section section--surface">
  <div class="container grid grid--2">
    <% contactCards.forEach((card) => { %>
      <div class="card">
        <h2 class="card__title">
          <%= card.title %>
        </h2>
        <ul class="list">
          <% (card.items || []).forEach((item) => { %>
            <li class="list__item">
              <strong>
                <%= item.label %>:
              </strong>
              <%
              const type = item.type;
              const value = item.value || "";
              if (type === "phone") { %>
                <a href="tel:<%= site.phone %>" data-ga-contact-method="call" data-ga-location="contacts_cards">
                  <%= site.phone %>
                </a>
              <% } else if (type === "telegram") { %>
                <% const href = item.href || site.telegram; %>
                <a href="<%= href %>" target="_blank" rel="noopener" data-ga-contact-method="telegram" data-ga-location="contacts_cards">
                  <%= value || href %>
                </a>
              <% } else if (type === "whatsapp") { %>
                <a href="https://wa.me/<%= waNumber %>" target="_blank" rel="noopener" data-ga-contact-method="whatsapp" data-ga-location="contacts_cards">
                  <%= value || site.phone %>
                </a>
              <% } else if (type === "viber") { %>
                <a href="<%= item.href || site.viber %>" target="_blank" rel="noopener" data-ga-contact-method="viber" data-ga-location="contacts_cards">
                  <%= value || site.phone %>
                </a>
              <% } else if (type === "facebook") { %>
                <% const href = item.href || site.facebook; %>
                <a href="<%= href %>" target="_blank" rel="noopener" data-ga-contact-method="facebook" data-ga-location="contacts_cards">
                  <%= value || href %>
                </a>
              <% } else if (type === "email") { %>
                <% const emailValue = value || site.email; %>
                <a href="mailto:<%= emailValue %>" data-ga-contact-method="email" data-ga-location="contacts_cards">
                  <%= emailValue %>
                </a>
              <% } else if (item.href) { %>
                <a href="<%= item.href %>"
                   target="<%= item.href.startsWith('http') ? '_blank' : '_self' %>"
                   rel="<%= item.href.startsWith('http') ? 'noopener' : '' %>">
                  <%= value %>
                </a>
              <% } else { %>
                <span>
                  <%= value %>
                </span>
              <% } %>
            </li>
          <% }); %>
        </ul>
        <% if (card.note) { %>
          <p class="card__text">
            <%= card.note %>
          </p>
        <% } %>
      </div>
    <% }); %>

    <% if (contactPage.quickLinks && contactPage.quickLinks.items && contactPage.quickLinks.items.length) { %>
      <div class="card card--elevated">
        <h2 class="card__title"><%= contactPage.quickLinks.title %></h2>
        <% if (contactPage.quickLinks.lead) { %>
          <p class="card__text"><%= contactPage.quickLinks.lead %></p>
        <% } %>
        <div class="section__actions">
          <% contactPage.quickLinks.items.forEach((item) => { %>
            <a class="button button--ghost" href="<%= lang.paths[item.key] %>" data-ga-content-type="contact_quick_link" data-ga-destination-key="<%= item.key %>" data-ga-location="contacts_quick_links">
              <%= item.label %>
            </a>
          <% }); %>
        </div>
      </div>
    <% } %>

    <% if (contactPage.cta) { %>
      <div class="card card--elevated">
        <h2 class="card__title">
          <%= lang.home.contact.title %>
        </h2>
        <p class="card__text">
          <%= lang.home.contact.lead %>
        </p>
        <div class="messenger-row">
          <a class="button button--secondary" href="<%= site.telegram %>" target="_blank" rel="noopener" data-ga-contact-method="telegram" data-ga-location="contacts_cta">
            <img class="button__icon" src="/assets/icons/social/tg.png" alt="Telegram icon" width="24" height="24">
            Telegram
          </a>
          <a class="button button--ghost" href="https://wa.me/<%= waNumber %>" target="_blank"
            rel="noopener" data-ga-contact-method="whatsapp" data-ga-location="contacts_cta">
            <img class="button__icon" src="/assets/icons/social/wh-1.png" alt="WhatsApp icon" width="24" height="24">
            WhatsApp
          </a>
          <a class="button button--ghost" href="<%= site.viber %>" target="_blank" rel="noopener" data-ga-contact-method="viber" data-ga-location="contacts_cta">
            <img class="button__icon" src="/assets/icons/social/viber.png" alt="Viber icon" width="24" height="24">
            Viber
          </a>
          <% if (site.facebook) { %>
            <a class="button button--ghost" href="<%= site.facebook %>" target="_blank" rel="noopener" data-ga-contact-method="facebook" data-ga-location="contacts_cta">
              <img class="button__icon" src="/assets/icons/social/fb.png" alt="Facebook icon" width="24" height="24">
              Facebook
            </a>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
</section>
