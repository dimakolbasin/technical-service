<% const page=lang.pages.prices; %>

  <section class="section section--surface">
    <div class="container">
      <div class="section__header">
        <h1 class="section__title">
          <%= page.heading %>
        </h1>
        <p class="section__lead">
          <%= page.lead %>
        </p>
      </div>
    </div>
  </section>

  <% if (page.sections && page.sections.length) { %>
    <% page.sections.forEach((section)=> { %>
      <section class="section">
        <div class="container">
          <div class="section__header">
            <h2 class="section__title">
              <%= section.title %>
            </h2>
            <% if (section.lead) { %>
              <p class="section__lead">
                <%= section.lead %>
              </p>
              <% } %>
          </div>

          <% if (section.items) { %>
            <ul class="price-list">
              <% section.items.forEach((item)=> { %>
                <li class="price-list__item">
                  <strong>
                    <%= item.label %>
                  </strong>
                  <span>
                    <%= item.value %>
                  </span>
                </li>
                <% }); %>
            </ul>
            <% } %>

              <% if (section.groups) { %>
                <div class="grid grid--2">
                  <% section.groups.forEach((group)=> { %>
                    <div class="card">
                      <h3 class="card__title">
                        <%= group.title %>
                      </h3>
                      <% if (group.lead) { %>
                        <p class="card__text">
                          <%= group.lead %>
                        </p>
                        <% } %>
                          <ul class="price-list">
                            <% group.items.forEach((item)=> { %>
                              <li class="price-list__item">
                                <strong>
                                  <%= item.label %>
                                </strong>
                                <span>
                                  <%= item.value %>
                                </span>
                              </li>
                              <% }); %>
                          </ul>
                    </div>
                    <% }); %>
                </div>
                <% } %>

                  <% if (section.note) { %>
                    <div class="card card--elevated">
                      <p class="card__text">
                        <%= section.note %>
                      </p>
                    </div>
                    <% } %>
        </div>
      </section>
      <% }); %>
        <% } else { %>
          <section class="section">
            <div class="container">
              <div class="card">
                <p class="card__text">
                  <%= page.lead %>
                </p>
              </div>
            </div>
          </section>
          <% } %>

            <% if (lang.serviceFocus) { %>
              <section class="section section--surface">
                <div class="container">
                  <div class="section__header">
                    <h2 class="section__title"><%= lang.serviceFocus.title %></h2>
                    <p class="section__lead"><%= lang.serviceFocus.lead %></p>
                  </div>
                  <div class="grid grid--3">
                    <% lang.serviceFocus.items.forEach((item)=> { %>
                      <article class="card">
                        <h3 class="card__title"><%= item.title %></h3>
                        <% if (item.text) { %>
                          <p class="card__text"><%= item.text %></p>
                        <% } %>
                        <a class="card__link" href="<%= lang.paths[item.key] %>" data-ga-content-type="service_focus_card" data-ga-destination-key="<%= item.key %>" data-ga-location="prices_service_focus">
                          <%= lang.serviceFocus.linkLabel %> — <%= item.title %>
                        </a>
                      </article>
                    <% }) %>
                  </div>
                </div>
              </section>
            <% } %>

            <% if (page.importantNotes && page.importantNotes.length) { %>
              <section class="section section--surface">
                <div class="container">
                  <div class="card">
                    <h3 class="card__title"><%= lang.common.important %></h3>
                    <ul class="list">
                      <% page.importantNotes.forEach((note)=> { %>
                        <li class="list__item">• <span>
                            <%= note %>
                          </span></li>
                        <% }); %>
                    </ul>
                  </div>
                </div>
              </section>
              <% } %>

                <% if (page.contactCard) { %>
                  <section class="section">
                    <div class="container">
                      <div class="card card--elevated">
                        <h3 class="card__title">
                          <%= page.contactCard.title %>
                        </h3>
                        <ul class="list">
                          <% page.contactCard.items.forEach((item)=> { %>
                            <li class="list__item">
                              <strong>
                                <%= item.label %>:
                              </strong>
                              <% const type = item.type;
                                const waNumber = site.phone.replace(/[^0-9]/g, '');
                                const value = item.value || "";
                                if (type === "phone") { %>
                                <a href="tel:<%= site.phone %>" data-ga-contact-method="call" data-ga-location="prices_contact_card">
                                  <%= site.phone %>
                                </a>
                              <% } else if (type === "telegram") { %>
                                <% const href = item.href || site.telegram; %>
                                <a href="<%= href %>" target="_blank" rel="noopener" data-ga-contact-method="telegram" data-ga-location="prices_contact_card">
                                  <%= value || href %>
                                </a>
                              <% } else if (type === "whatsapp") { %>
                                <a href="https://wa.me/<%= waNumber %>" target="_blank" rel="noopener" data-ga-contact-method="whatsapp" data-ga-location="prices_contact_card">
                                  <%= value || site.phone %>
                                </a>
                              <% } else if (type === "viber") { %>
                                <a href="<%= item.href || site.viber %>" target="_blank" rel="noopener" data-ga-contact-method="viber" data-ga-location="prices_contact_card">
                                  <%= value || site.phone %>
                                </a>
                              <% } else if (type === "facebook") { %>
                                <% const href = item.href || site.facebook; %>
                                <a href="<%= href %>" target="_blank" rel="noopener" data-ga-contact-method="facebook" data-ga-location="prices_contact_card">
                                  <%= value || href %>
                                </a>
                              <% } else if (type === "email") { %>
                                <% const emailValue = value || site.email; %>
                                <a href="mailto:<%= emailValue %>" data-ga-contact-method="email" data-ga-location="prices_contact_card">
                                  <%= emailValue %>
                                </a>
                              <% } else if (item.href) { %>
                                <a href="<%= item.href %>" target="<%= item.href.startsWith('http') ? '_blank' : '_self' %>"
                                  rel="<%= item.href.startsWith('http') ? 'noopener' : '' %>">
                                  <%= value %>
                                </a>
                              <% } else { %>
                                <span>
                                  <%= value %>
                                </span>
                              <% } %>
                            </li>
                            <% }); %>
                        </ul>
                      </div>
                    </div>
                  </section>
                  <% } %>
